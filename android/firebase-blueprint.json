{
  "entities": {
    "User": {
      "title": "User",
      "description": "Military personnel profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "rank": { "type": "string" },
        "ala": { "type": "number", "description": "1, 2, 3 or 4" },
        "email": { "type": "string" },
        "photoURL": { "type": "string" }
      },
      "required": ["uid", "name", "ala", "email"]
    },
    "Permuta": {
      "title": "Permuta",
      "description": "A request to swap a shift",
      "type": "object",
      "properties": {
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "requesterRg": { "type": "string" },
        "substituteRg": { "type": "string" },
        "substituteName": { "type": "string" },
        "date": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
        "originalAla": { "type": "number", "description": "1, 2, 3 or 4" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "cancelled"] },
        "acceptedById": { "type": "string" },
        "acceptedByName": { "type": "string" },
        "requesterSigned": { "type": "boolean" },
        "substituteSigned": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requesterId", "requesterRg", "date", "originalAla", "status", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Stores military profiles"
    },
    "/permutas/{permutaId}": {
      "schema": "Permuta",
      "description": "Stores shift swap requests"
    },
    "/militaries/{rg}": {
      "schema": "User",
      "description": "Internal database of military personnel synchronized from Sheet"
    },
    "/vacation_preferences/{rg}": {
      "description": "Stores user preferred months for vacations (up to 3)",
      "schema": {
        "type": "object",
        "properties": {
          "rg": { "type": "string" },
          "months": { "type": "array", "items": { "type": "string" } },
          "year": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        },
        "required": ["rg", "months", "year"]
      }
    },
    "/config/vacation_settings": {
      "description": "Global settings for the vacation module controlled by Escalante",
      "schema": {
        "type": "object",
        "properties": {
          "preferencesEnabled": { "type": "boolean" },
          "updatedBy": { "type": "string" },
          "updatedAt": { "type": "string", "format": "date-time" }
        }
      }
    }
  }
}
