rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Check if user is the owner of a document via a 'users' record
    // This assumes we have a /users/{uid} document that stores the user's RG
    function isRgOwner(rg) {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rg == rg;
    }

    function isAdmin() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // --- Users Collection ---
    // Minimal profile to link UID to RG
    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      // Users can only be created/updated by the system (server.ts) or with strict validation
      allow create, update: if false; // System handles this via Admin SDK
    }

    // --- Militaries Collection ---
    // Read-only reference data
    match /militaries/{rg} {
      allow get: if isSignedIn() && isValidId(rg);
      allow list: if isSignedIn();
      allow write: if false; // Only server.ts can write
    }

    // --- Permutas Collection ---
    function isValidPermuta(data) {
      return data.requesterId is string &&
             data.requesterName is string && data.requesterName.size() <= 200 &&
             data.requesterRg is string && data.requesterRg.size() <= 20 &&
             data.date is string && data.date.matches('^\\d{4}-\\d{2}-\\d{2}$') &&
             (data.originalAla is int || data.originalAla is string) &&
             data.status in ['pending', 'accepted', 'rejected', 'cancelled'] &&
             data.createdAt == request.time &&
             data.updatedAt == request.time;
    }

    match /permutas/{permutaId} {
      allow list: if isSignedIn();
      allow get: if isSignedIn();
      
      allow create: if isSignedIn() && 
                      isValidPermuta(incoming()) &&
                      incoming().requesterId == request.auth.uid;

      allow update: if isSignedIn() && (
        // Action: Sign as Substitute
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['substituteSigned', 'updatedAt', 'status']) &&
          incoming().substituteRg == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.rg &&
          incoming().updatedAt == request.time
        ) ||
        // Action: Cancel by owner
        (
          incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt']) &&
          existing().requesterId == request.auth.uid &&
          incoming().status == 'cancelled' &&
          incoming().updatedAt == request.time
        ) ||
        // Admin override
        isAdmin()
      );

      allow delete: if isAdmin();
    }

    // --- Vacation Preferences ---
    function isValidVacationPref(data) {
      return data.rg is string &&
             data.months is list &&
             data.months.size() <= 3 &&
             data.year is string &&
             data.updatedAt == request.time;
    }

    match /vacation_preferences/{rg} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      allow create, update: if isSignedIn() && 
                             isRgOwner(rg) && 
                             isValidVacationPref(incoming()) &&
                             (get(/databases/$(database)/documents/config/vacation_settings).data.preferencesEnabled == true || isAdmin());
      allow delete: if isAdmin() || isRgOwner(rg);
    }

    // --- Config Collection ---
    match /config/{configId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
  }
}
