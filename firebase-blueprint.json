{
  "entities": {
    "Military": {
      "title": "Military",
      "description": "Military personnel profile and synchronized role/permissions from the Sheet",
      "type": "object",
      "properties": {
        "rg": { "type": "string" },
        "name": { "type": "string" },
        "warName": { "type": "string" },
        "rank": { "type": "string" },
        "ala": { "type": "string" },
        "obm": { "type": "string" },
        "email": { "type": "string" },
        "cel": { "type": "string" },
        "quadro": { "type": "string" },
        "idFuncional": { "type": "string" },
        "birthDate": { "type": "string" },
        "isAdmin": { "type": "boolean" },
        "isEscalante": { "type": "boolean" },
        "isRefeitorioAdmin": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["rg", "name"]
    },
    "OutsourcedUser": {
      "title": "OutsourcedUser",
      "description": "Non-military personnel (civilians) with platform access for specialized administration (e.g. kitchen)",
      "type": "object",
      "properties": {
        "login": { "type": "string" },
        "name": { "type": "string" },
        "customPassword": { "type": "string" },
        "isRefeitorioAdmin": { "type": "boolean" },
        "isAdmin": { "type": "boolean" },
        "isEscalante": { "type": "boolean" },
        "obm": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["login", "name"]
    },
    "RefeitorioData": {
      "title": "RefeitorioData",
      "description": "Configuration data, catalog, and menu details for the mess/refeitorio",
      "type": "object",
      "properties": {
        "menus": { "type": "array" },
        "catalog": { "type": "array" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Permuta": {
      "title": "Permuta",
      "description": "A request to swap a shift between two military members",
      "type": "object",
      "properties": {
        "requesterId": { "type": "string" },
        "requesterName": { "type": "string" },
        "requesterRg": { "type": "string" },
        "substituteRg": { "type": "string" },
        "substituteName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "originalAla": { "type": "number" },
        "status": { "type": "string", "enum": ["pending", "accepted", "rejected", "cancelled"] },
        "acceptedById": { "type": "string" },
        "acceptedByName": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["requesterRg", "date", "status", "createdAt"]
    },
    "Escala": {
      "title": "Escala",
      "description": "Officer scales or duty scales configured for active operational environments",
      "type": "object",
      "properties": {
        "days": { "type": "object" },
        "updatedAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/militaries/{rg}": {
      "schema": "Military",
      "description": "Collection storing military personnel records"
    },
    "/outsourced_users/{login}": {
      "schema": "OutsourcedUser",
      "description": "Collection storing non-military (civilian) user records"
    },
    "/refeitorio/{id}": {
      "schema": "RefeitorioData",
      "description": "Stores mess hall menus, dynamic catalogs and meal tracking details"
    },
    "/permutas/{permutaId}": {
      "schema": "Permuta",
      "description": "Registry of service swap requests between personnel"
    },
    "/officer_scales/{docId}": {
      "schema": "Escala",
      "description": "Operational schedules for officers"
    },
    "/grd_configs/{docId}": {
      "schema": "Escala",
      "description": "GRD configuration tables and calendars"
    }
  }
}
