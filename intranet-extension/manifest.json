{
  "manifest_version": 3,
  "name": "DGP Helper - Extração Fluida",
  "version": "2.0",
  "description": "Extensão para extrair dados de férias do DGP de forma automática para o Google Sheets.",
  "permissions": ["tabs", "scripting", "storage"],
  "host_permissions": [
    "https://cbmerj.rj.gov.br/*",
    "http://cbmerj.rj.gov.br/*",
    "https://script.google.com/*",
    "https://script.googleusercontent.com/*",
    "https://ais-dev-zrzalylqdof6lo5c3vm2nd-725468355119.us-east1.run.app/*",
    "https://ais-pre-zrzalylqdof6lo5c3vm2nd-725468355119.us-east1.run.app/*"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://cbmerj.rj.gov.br/dgp/*",
        "http://cbmerj.rj.gov.br/dgp/*"
      ],
      "js": ["content.js"]
    }
  ]
}
